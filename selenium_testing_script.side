    {
      "id": "test-language-switch-french",
      "name": "11. Switch Language to French",
      "commands": [
        {
          "id": "cmd-lf-1",
          "command": "open",
          "target": "https://www.amazon.ca/?language=fr_CA",
          "value": ""
        },
        {
          "id": "cmd-lf-2",
          "command": "pause",
          "target": "6000",
          "value": ""
        },
        {
          "id": "cmd-lf-3",
          "command": "assertElementPresent",
          "target": "css=#nav-logo",
          "value": ""
        },
        {
          "id": "cmd-lf-4",
          "command": "executeScript",
          "target": "const lang = document.documentElement.lang || ''; const url = window.location.href; const cookie = document.cookie; const body = document.body.innerText; return String(lang.startsWith('fr') || url.includes('language=fr_CA') || cookie.includes('lc-acbca=fr_CA') || body.includes('Panier') || body.includes('Compte et listes') || body.includes('Bonjour'));",
          "value": "isFrench"
        },
        {
          "id": "cmd-lf-5",
          "command": "assert",
          "target": "isFrench",
          "value": "true"
        },
        {
          "id": "cmd-lf-6",
          "command": "executeScript",
          "target": "return String(document.querySelector('#nav-belt') !== null);",
          "value": "navLoaded"
        },
        {
          "id": "cmd-lf-7",
          "command": "assert",
          "target": "navLoaded",
          "value": "true"
        },
        {
