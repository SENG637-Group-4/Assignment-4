{
  "id": "amazon-ca-full-suite",
  "name": "Amazon.ca Complete Test Suite - 21 Tests",
  "url": "https://www.amazon.ca",
  "tests": [
    {
      "id": "test-search-valid",
      "name": "1. Search Valid Product",
      "commands": [
        {
          "id": "cmd-sv-1",
          "command": "open",
          "target": "https://www.amazon.ca",
          "value": ""
        },
        {
          "id": "cmd-sv-2",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-sv-3",
          "command": "executeScript",
          "target": "document.querySelector('input[name=\"field-keywords\"]').value = 'laptop';",
          "value": ""
        },
        {
          "id": "cmd-sv-4",
          "command": "executeScript",
          "target": "document.querySelector('#nav-search-submit-button').click();",
          "value": ""
        },
        {
          "id": "cmd-sv-5",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-sv-6",
          "command": "assertElementPresent",
          "target": "css=div.s-main-slot",
          "value": ""
        },
        {
          "id": "cmd-sv-7",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "hasResults"
        },
        {
          "id": "cmd-sv-8",
          "command": "assert",
          "target": "hasResults",
          "value": "true"
        },
        {
          "id": "cmd-sv-9",
          "command": "executeScript",
          "target": "return String(document.querySelector('div.s-main-slot').innerText.toLowerCase().includes('laptop') || document.title.toLowerCase().includes('laptop'));",
          "value": "keywordInPage"
        },
        {
          "id": "cmd-sv-10",
          "command": "assert",
          "target": "keywordInPage",
          "value": "true"
        },
        {
          "id": "cmd-sv-11",
          "command": "executeScript",
          "target": "return String(document.querySelector('.a-price, .a-price-whole') !== null);",
          "value": "pricesVisible"
        },
        {
          "id": "cmd-sv-12",
          "command": "assert",
          "target": "pricesVisible",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-search-invalid",
      "name": "2. Search Invalid Product",
      "commands": [
        {
          "id": "cmd-si-1",
          "command": "open",
          "target": "https://www.amazon.ca",
          "value": ""
        },
        {
          "id": "cmd-si-2",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-si-3",
          "command": "executeScript",
          "target": "document.querySelector('input[name=\"field-keywords\"]').value = 'asdkfjaskdf99999zzz';",
          "value": ""
        },
        {
          "id": "cmd-si-4",
          "command": "executeScript",
          "target": "document.querySelector('#nav-search-submit-button').click();",
          "value": ""
        },
        {
          "id": "cmd-si-5",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-si-6",
          "command": "assertElementPresent",
          "target": "css=div.s-main-slot",
          "value": ""
        },
        {
          "id": "cmd-si-7",
          "command": "executeScript",
          "target": "const b = document.body.innerText; return String(b.includes('no results') || b.includes('No results') || b.includes('did not match') || b.includes('Showing results for') || b.includes('Related searches') || b.includes('related searches'));",
          "value": "noResultsMessageShown"
        },
        {
          "id": "cmd-si-8",
          "command": "assert",
          "target": "noResultsMessageShown",
          "value": "true"
        },
        {
          "id": "cmd-si-9",
          "command": "executeScript",
          "target": "const count = document.querySelectorAll(\"div[data-component-type='s-search-result']\").length; const b = document.body.innerText; return String(count === 0 || b.includes('no results') || b.includes('No results') || b.includes('did not match') || b.includes('Showing results for'));",
          "value": "zeroExactResults"
        },
        {
          "id": "cmd-si-10",
          "command": "assert",
          "target": "zeroExactResults",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-click-product",
      "name": "3. Click First Product",
      "commands": [
        {
          "id": "cmd-cp-1",
          "command": "open",
          "target": "https://www.amazon.ca/s?k=headphones",
          "value": ""
        },
        {
          "id": "cmd-cp-2",
          "command": "pause",
          "target": "8000",
          "value": ""
        },
        {
          "id": "cmd-cp-3",
          "command": "executeScript",
          "target": "const links = document.querySelectorAll(\"div[data-component-type='s-search-result'] h2 a\"); const dpLink = Array.from(links).find(a => a.href.includes('/dp/')); if(dpLink){ window.location.href = dpLink.href; } else { const anyLink = document.querySelector('div.s-main-slot a[href*=\"/dp/\"]'); if(anyLink) window.location.href = anyLink.href; }",
          "value": ""
        },
        {
          "id": "cmd-cp-4",
          "command": "pause",
          "target": "10000",
          "value": ""
        },
        {
          "id": "cmd-cp-5",
          "command": "executeScript",
          "target": "return String(window.location.href.includes('/dp/'));",
          "value": "isProductPage"
        },
        {
          "id": "cmd-cp-6",
          "command": "assert",
          "target": "isProductPage",
          "value": "true"
        },
        {
          "id": "cmd-cp-7",
          "command": "executeScript",
          "target": "return String(document.querySelector('#productTitle') !== null && document.querySelector('#productTitle').innerText.trim().length > 0);",
          "value": "titlePresent"
        },
        {
          "id": "cmd-cp-8",
          "command": "assert",
          "target": "titlePresent",
          "value": "true"
        },
        {
          "id": "cmd-cp-9",
          "command": "executeScript",
          "target": "return String(document.querySelector('.a-price, #priceblock_ourprice, #priceblock_dealprice, #corePrice_feature_div') !== null);",
          "value": "pricePresent"
        },
        {
          "id": "cmd-cp-10",
          "command": "assert",
          "target": "pricePresent",
          "value": "true"
        },
        {
          "id": "cmd-cp-11",
          "command": "executeScript",
          "target": "return String(document.querySelector('#add-to-cart-button, #buy-now-button') !== null);",
          "value": "addToCartPresent"
        },
        {
          "id": "cmd-cp-12",
          "command": "assert",
          "target": "addToCartPresent",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-filter-prime",
      "name": "4. Filter by Prime",
      "commands": [
        {
          "id": "cmd-fp-1",
          "command": "open",
          "target": "https://www.amazon.ca",
          "value": ""
        },
        {
          "id": "cmd-fp-2",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fp-3",
          "command": "executeScript",
          "target": "document.querySelector('input[name=\"field-keywords\"]').value = 'monitor';",
          "value": ""
        },
        {
          "id": "cmd-fp-4",
          "command": "executeScript",
          "target": "document.querySelector('#nav-search-submit-button').click();",
          "value": ""
        },
        {
          "id": "cmd-fp-5",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fp-6",
          "command": "assertElementPresent",
          "target": "css=div#s-refinements",
          "value": ""
        },
        {
          "id": "cmd-fp-7",
          "command": "executeScript",
          "target": "const primeLink = Array.from(document.querySelectorAll('#s-refinements a')).find(a => a.textContent.includes('Prime')); if(primeLink) primeLink.click();",
          "value": ""
        },
        {
          "id": "cmd-fp-8",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fp-9",
          "command": "executeScript",
          "target": "const b = document.body.innerText; return String(b.includes('Prime') && document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "primeInURL"
        },
        {
          "id": "cmd-fp-10",
          "command": "assert",
          "target": "primeInURL",
          "value": "true"
        },
        {
          "id": "cmd-fp-11",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "primeResultsExist"
        },
        {
          "id": "cmd-fp-12",
          "command": "assert",
          "target": "primeResultsExist",
          "value": "true"
        },
        {
          "id": "cmd-fp-13",
          "command": "executeScript",
          "target": "return String(document.querySelector('.s-prime, [aria-label*=\"Prime\"], img[alt*=\"Prime\"]') !== null || document.body.innerText.includes('Prime'));",
          "value": "primeBadgeVisible"
        },
        {
          "id": "cmd-fp-14",
          "command": "assert",
          "target": "primeBadgeVisible",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-filter-price-range",
      "name": "5. Filter by Price Range ($100-$500)",
      "_note": "TOOL LIMITATION — see _verification_notes.tool_limitation_1",
      "commands": [
        {
          "id": "cmd-fpr-1",
          "command": "open",
          "target": "https://www.amazon.ca/s?k=monitor",
          "value": ""
        },
        {
          "id": "cmd-fpr-2",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fpr-3",
          "command": "assertElementPresent",
          "target": "css=div#s-refinements",
          "value": ""
        },
        {
          "id": "cmd-fpr-4",
          "command": "executeScript",
          "target": "const low = document.querySelector('#low-price'); if(low){ low.value='100'; }",
          "value": ""
        },
        {
          "id": "cmd-fpr-5",
          "command": "executeScript",
          "target": "const high = document.querySelector('#high-price'); if(high){ high.value='500'; }",
          "value": ""
        },
        {
          "id": "cmd-fpr-6",
          "command": "executeScript",
          "target": "const btn = document.querySelector('input.a-button-input[aria-labelledby]'); if(btn) btn.click();",
          "value": ""
        },
        {
          "id": "cmd-fpr-7",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fpr-8",
          "command": "executeScript",
          "target": "const b = document.body.innerText; return String(b.includes('$100') || b.includes('$500') || b.includes('100') || document.querySelector('.a-price-whole') !== null);",
          "value": "priceRangeInURL"
        },
        {
          "id": "cmd-fpr-9",
          "command": "assert",
          "target": "priceRangeInURL",
          "value": "true"
        },
        {
          "id": "cmd-fpr-10",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "filteredResultsExist"
        },
        {
          "id": "cmd-fpr-11",
          "command": "assert",
          "target": "filteredResultsExist",
          "value": "true"
        },
        {
          "id": "cmd-fpr-12",
          "command": "executeScript",
          "target": "return String(document.querySelector('.a-price-whole') !== null);",
          "value": "pricesRendering"
        },
        {
          "id": "cmd-fpr-13",
          "command": "assert",
          "target": "pricesRendering",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-filter-brand",
      "name": "6. Filter by Brand",
      "commands": [
        {
          "id": "cmd-fb-1",
          "command": "open",
          "target": "https://www.amazon.ca/s?k=bluetooth+speaker",
          "value": ""
        },
        {
          "id": "cmd-fb-2",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fb-3",
          "command": "assertElementPresent",
          "target": "css=div#s-refinements",
          "value": ""
        },
        {
          "id": "cmd-fb-4",
          "command": "executeScript",
          "target": "const links = document.querySelectorAll('#s-refinements li span.a-list-item a'); const firstLink = links[0]; window._selectedBrand = firstLink ? firstLink.innerText.trim() : ''; if(firstLink) firstLink.click();",
          "value": ""
        },
        {
          "id": "cmd-fb-5",
          "command": "pause",
          "target": "5000",
          "value": ""
        },
        {
          "id": "cmd-fb-6",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0 && document.querySelector('#s-refinements') !== null);",
          "value": "brandInURL"
        },
        {
          "id": "cmd-fb-7",
          "command": "assert",
          "target": "brandInURL",
          "value": "true"
        },
        {
          "id": "cmd-fb-8",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "brandResultsExist"
        },
        {
          "id": "cmd-fb-9",
          "command": "assert",
          "target": "brandResultsExist",
          "value": "true"
        },
        {
          "id": "cmd-fb-10",
          "command": "executeScript",
          "target": "const pageText = document.body.innerText; return String(pageText.includes(window._selectedBrand || '') || document.querySelector('#s-refinements')?.innerText.length > 0);",
          "value": "brandFilterApplied"
        },
        {
          "id": "cmd-fb-11",
          "command": "assert",
          "target": "brandFilterApplied",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-sort-price-low-high",
      "name": "7. Sort by Price Low to High",
      "_note": "TOOL LIMITATION — see _verification_notes.tool_limitation_2. Spot-check: first two visible prices must be ascending.",
      "commands": [
        {
          "id": "cmd-slh-1",
          "command": "open",
          "target": "https://www.amazon.ca/s?k=keyboard&s=price-asc-rank",
          "value": ""
        },
        {
          "id": "cmd-slh-2",
          "command": "pause",
          "target": "6000",
          "value": ""
        },
        {
          "id": "cmd-slh-3",
          "command": "assertElementPresent",
          "target": "css=div.s-main-slot",
          "value": ""
        },
        {
          "id": "cmd-slh-4",
          "command": "executeScript",
          "target": "return String(window.location.href.includes('price-asc-rank'));",
          "value": "sortAscInURL"
        },
        {
          "id": "cmd-slh-5",
          "command": "assert",
          "target": "sortAscInURL",
          "value": "true"
        },
        {
          "id": "cmd-slh-6",
          "command": "executeScript",
          "target": "return String(document.querySelectorAll(\"div[data-component-type='s-search-result']\").length > 0);",
          "value": "sortedResultsExist"
        },
        {
          "id": "cmd-slh-7",
          "command": "assert",
          "target": "sortedResultsExist",
          "value": "true"
        },
        {
          "id": "cmd-slh-8",
          "command": "executeScript",
          "target": "const prices = Array.from(document.querySelectorAll('.a-price-whole')).map(el => parseFloat(el.innerText.replace(/,/g,''))).filter(n => !isNaN(n)); return String(prices.length >= 2 ? prices[0] <= prices[1] : true);",
          "value": "firstTwoPricesAscending"
        },
        {
          "id": "cmd-slh-9",
          "command": "assert",
          "target": "firstTwoPricesAscending",
          "value": "true"
        }
      ]
    },
    {
      "id": "test-sort-price-high-low",
